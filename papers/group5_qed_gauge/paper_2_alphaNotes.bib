@FOOTNOTE{Note1,key="Note1",note="The selection principle $B/N = 3$ is algebraically proven (Sec.~III), and the Casimir identity $\langle C_3\rangle _n = C_4(n)$ connects $B$ to the $SO(4)$ representation theory. The remaining gap: why the degeneracy-weighted Casimir trace specifically (rather than some other spectral quantity) for each bundle component. The second selection principle (Sec.~\ref {sec:second_selection}) provides independent support."}
@FOOTNOTE{Note2,key="Note2",note="The Hermiticity of the circulant is now proven: $b$ and $c$ are necessarily complex conjugates (Sec.~VI\protect \,D). This is consistent with $U(1)$ gauge structure but does not yet derive $bc = K/3$."}
